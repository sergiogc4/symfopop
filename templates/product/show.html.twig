{% extends 'base.html.twig' %}

{% block title %}{{ product.title }} - SymfoPop{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-6">
        <img src="{{ product.image }}" class="img-fluid rounded" alt="{{ product.title }}">
    </div>
    <div class="col-md-6">
        <h1>{{ product.title }}</h1>
        <h3 class="text-success">{{ product.price|number_format(2, ',', '.') }} €</h3>
        <p class="mt-3">{{ product.description }}</p>
        <p class="text-muted">
            Publicat per <strong>{{ product.owner.name }}</strong>
            el {{ product.createdAt|date('d/m/Y') }}
        </p>

        {% if app.user == product.owner %}
            <div class="d-flex gap-2 mt-3">
                <a href="{{ path('app_product_edit', {id: product.id}) }}" class="btn btn-warning">Editar</a>
                <form method="post" action="{{ path('app_product_delete', {id: product.id}) }}" onsubmit="return confirm('Segur que vols esborrar aquest producte?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                    <button class="btn btn-danger">Esborrar</button>
                </form>
            </div>
        {% endif %}

        <a href="{{ path('app_product_index') }}" class="btn btn-secondary mt-3">← Tornar al llistat</a>
    </div>
</div>
{% endblock %}
